<Application x:Class="PGInstaller.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Material Design Theme Setup -->
                <materialDesign:BundledTheme BaseTheme="Light" PrimaryColor="Green" SecondaryColor="Lime" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml" />

                <!-- Custom Brand Brushes -->
                <ResourceDictionary>
                    <SolidColorBrush x:Key="PGGreen" Color="#00843D" />
                    <SolidColorBrush x:Key="PGDarkGreen" Color="#005C2B" />
                    <SolidColorBrush x:Key="PGGold" Color="#F2C94C" />
                    <SolidColorBrush x:Key="PGRed" Color="#C0392B" />
                    <SolidColorBrush x:Key="PGPurple" Color="#8E44AD" />
                    <SolidColorBrush x:Key="PGBlue" Color="#2980B9" />
                    <SolidColorBrush x:Key="PGDarkBlue" Color="#34495E" />
                    <SolidColorBrush x:Key="PGTextDark" Color="#2C3E50" />
                    <SolidColorBrush x:Key="PGTextLight" Color="#7F8C8D" />
                </ResourceDictionary>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
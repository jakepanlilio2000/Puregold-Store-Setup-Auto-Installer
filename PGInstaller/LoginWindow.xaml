<Window x:Class="PGInstaller.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Authentication Required" Height="300" Width="400"
        WindowStartupLocation="CenterScreen" WindowStyle="None"
        ResizeMode="NoResize" Background="Transparent" AllowsTransparency="True">

    <Border Background="{StaticResource PGDarkBlue}" CornerRadius="10" BorderBrush="#34495E" BorderThickness="1">
        <StackPanel Margin="15">
            <materialDesign:PackIcon Kind="Lock" Width="48" Height="48" HorizontalAlignment="Center" Foreground="{StaticResource PGGold}" />
            <TextBlock Text="PG-AIO SECURITY" FontSize="22" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,10,0,0" />
            <TextBlock Text="Enter access key to proceed" FontSize="12" Foreground="#BDC3C7" HorizontalAlignment="Center" Margin="0,5,0,20" />

            <PasswordBox x:Name="TxtPassword" 
                         Style="{StaticResource MaterialDesignPasswordBox}"
                         materialDesign:HintAssist.Hint="Access Key"
                         materialDesign:HintAssist.Foreground="{StaticResource PGGold}"
                         Foreground="White" FontSize="16"
                         KeyDown="TxtPassword_KeyDown" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,30,0,0">
                <Button Content="EXIT" Width="100" Style="{StaticResource MaterialDesignRaisedButton}" 
                        Background="{StaticResource PGRed}" Foreground="White" Margin="0,0,10,0" Click="BtnExit_Click"/>
                <Button Content="UNLOCK" Width="100" Style="{StaticResource MaterialDesignRaisedButton}" 
                        Background="{StaticResource PGGreen}" Foreground="White" Click="BtnLogin_Click"/>
            </StackPanel>

            <TextBlock Text="Designed for Zone 11, developed by Jake Ashley Panlilio IT - San Fernando"
                       Foreground="#95A5A6" FontSize="10" HorizontalAlignment="Center" Margin="0,30,0,0" TextWrapping="Wrap" TextAlignment="Center"/>
        </StackPanel>
    </Border>
</Window>
<Window
    x:Class="PGInstaller.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:PGInstaller.Viewmodel"
    Title="PG-AIO Installer v1.4"
    Width="1200"
    Height="850"
    MinWidth="1000"
    MinHeight="700"
    Background="{DynamicResource MaterialDesignPaper}"
    FontFamily="{materialDesign:MaterialDesignFont}"
    ResizeMode="CanResize"
    Style="{StaticResource MaterialDesignWindow}"
    TextElement.Foreground="{DynamicResource MaterialDesignBody}"
    WindowStartupLocation="CenterScreen"
    WindowState="Maximized"
    mc:Ignorable="d">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <SolidColorBrush x:Key="PGGreen" Color="#00843D" />
        <SolidColorBrush x:Key="PGDarkGreen" Color="#005C2B" />
        <SolidColorBrush x:Key="PGGold" Color="#F2C94C" />
        <SolidColorBrush x:Key="PGRed" Color="#C0392B" />
        <SolidColorBrush x:Key="PGPurple" Color="#8E44AD" />
        <SolidColorBrush x:Key="PGBlue" Color="#2980B9" />
        <SolidColorBrush x:Key="PGDarkBlue" Color="#34495E" />
        <SolidColorBrush x:Key="PGTextDark" Color="#2C3E50" />
        <SolidColorBrush x:Key="PGTextLight" Color="#7F8C8D" />
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="340" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border
            Grid.Column="0"
            Background="#FFFFFF"
            BorderBrush="#E2E8F0"
            BorderThickness="0,0,1,0">
            <DockPanel>
                <StackPanel Margin="24,32,24,16" DockPanel.Dock="Top">
                    <StackPanel Orientation="Horizontal">
                        <Border
                            Width="44"
                            Height="44"
                            Background="#00843D"
                            CornerRadius="10">
                            <materialDesign:PackIcon
                                Width="26"
                                Height="26"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Foreground="White"
                                Kind="PackageVariant" />
                        </Border>
                        <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock
                                FontSize="20"
                                FontWeight="Bold"
                                Foreground="#0F172A"
                                Text="PG INSTALLER" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
                <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="24,0,24,32">
                        <TextBlock
                            Margin="0,16,0,8"
                            Foreground="#64748B"
                            Style="{StaticResource MaterialDesignOverlineTextBlock}"
                            Text="CONFIGURATION" />
                        <materialDesign:Card
                            Margin="0,0,0,20"
                            Padding="16"
                            Background="#F8FAFC"
                            BorderThickness="0"
                            UniformCornerRadius="12">
                            <StackPanel>
                                <ComboBox
                                    materialDesign:HintAssist.Hint="Select Department"
                                    ItemsSource="{Binding Departments}"
                                    SelectedItem="{Binding SelectedDepartment}"
                                    Style="{StaticResource MaterialDesignOutlinedComboBox}" />
                            </StackPanel>
                        </materialDesign:Card>

                        <Expander
                            HorizontalAlignment="Stretch"
                            IsExpanded="True"
                            Style="{StaticResource MaterialDesignExpander}">
                            <Expander.Header>
                                <TextBlock
                                    VerticalAlignment="Center"
                                    Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                                    Text="Network Settings" />
                            </Expander.Header>
                            <materialDesign:Card
                                Margin="0,8,0,20"
                                Padding="16"
                                Background="#F8FAFC"
                                BorderThickness="0"
                                UniformCornerRadius="12">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox
                                            Grid.Column="0"
                                            materialDesign:HintAssist.Hint="IP Address"
                                            Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                            Text="{Binding TargetIp}" />
                                        <TextBox
                                            Grid.Column="2"
                                            materialDesign:HintAssist.Hint="Gateway"
                                            Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                            Text="{Binding TargetGateway}" />
                                    </Grid>
                                    <TextBox
                                        Margin="0,12,0,12"
                                        materialDesign:HintAssist.Hint="Primary DNS"
                                        Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                        Text="{Binding TargetDns}" />
                                    <Button
                                        HorizontalAlignment="Stretch"
                                        materialDesign:ButtonAssist.CornerRadius="8"
                                        Background="#F2C94C"
                                        Command="{Binding ChangeIpCommand}"
                                        Content="APPLY CONFIG"
                                        Foreground="#0F172A"
                                        Style="{StaticResource MaterialDesignRaisedButton}" />
                                </StackPanel>
                            </materialDesign:Card>
                        </Expander>

                        <TextBlock
                            Margin="0,16,0,8"
                            Foreground="#64748B"
                            Style="{StaticResource MaterialDesignOverlineTextBlock}"
                            Text="INSTALL MANIFEST" />
                        <materialDesign:Card
                            MaxHeight="260"
                            Padding="0"
                            Background="#F8FAFC"
                            BorderThickness="0"
                            UniformCornerRadius="12">
                            <ListBox
                                Background="Transparent"
                                BorderThickness="0"
                                ItemsSource="{Binding PreviewList}"
                                Style="{StaticResource MaterialDesignListBox}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="12,6" Orientation="Horizontal">
                                            <materialDesign:PackIcon
                                                Margin="0,0,10,0"
                                                VerticalAlignment="Center"
                                                Foreground="#00843D"
                                                Kind="CheckCircle" />
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                Style="{StaticResource MaterialDesignBody2TextBlock}"
                                                Text="{Binding}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </materialDesign:Card>

                        <StackPanel Margin="0,28,0,0">
                            <CheckBox
                                Content="Create System Restore Point"
                                IsChecked="{Binding IsRestorePointEnabled}"
                                Style="{StaticResource MaterialDesignCheckBox}"
                                ToolTip="Will be unchecked if System Restore is disabled in Windows." />

                            <Button
                                Height="60"
                                Margin="0,20,0,0"
                                HorizontalAlignment="Stretch"
                                materialDesign:ButtonAssist.CornerRadius="12"
                                Background="#00843D"
                                Command="{Binding InstallCommand}"
                                Content="START INSTALLATION"
                                FontSize="16"
                                FontWeight="Bold"
                                Foreground="White"
                                Style="{StaticResource MaterialDesignRaisedButton}">
                                <Button.Effect>
                                    <DropShadowEffect
                                        BlurRadius="16"
                                        Opacity="0.25"
                                        ShadowDepth="6"
                                        Color="#00843D" />
                                </Button.Effect>
                            </Button>
                        </StackPanel>
                        <StackPanel Margin="0,40,0,0" HorizontalAlignment="Center">
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="11"
                                Foreground="#64748B"
                                Text="Ensure 'Assets' folder is present." />
                            <TextBlock
                                Margin="0,4,0,0"
                                HorizontalAlignment="Center"
                                FontSize="11"
                                Foreground="#94A3B8"
                                Text="Designed for Zone 11" />
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="11"
                                Foreground="#94A3B8"
                                Text="Developed by Jake Ashley Panlilio IT" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>
        <ScrollViewer
            Grid.Column="1"
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="40,40,40,40">
                <StackPanel Margin="0,0,0,32">
                    <TextBlock
                        FontWeight="Bold"
                        Style="{StaticResource MaterialDesignHeadline4TextBlock}"
                        Text="Dashboard" />
                    <TextBlock
                        Margin="0,6,0,0"
                        Foreground="#64748B"
                        Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                        Text="Manage system maintenance, recovery, and tools." />
                </StackPanel>
                <TextBlock
                    Margin="0,0,0,12"
                    Foreground="#64748B"
                    Style="{StaticResource MaterialDesignOverlineTextBlock}"
                    Text="QUICK MAINTENANCE" />
                <materialDesign:Card
                    Margin="0,0,0,32"
                    Padding="24"
                    UniformCornerRadius="16">
                    <WrapPanel>
                        <Button
                            Width="160"
                            Height="120"
                            Margin="0,0,16,16"
                            materialDesign:ButtonAssist.CornerRadius="12"
                            Background="#FEF2F2"
                            Command="{Binding RunDefenderCommand}"
                            Foreground="#991B1B"
                            Style="{StaticResource MaterialDesignRaisedButton}">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <materialDesign:PackIcon
                                    Width="32"
                                    Height="32"
                                    HorizontalAlignment="Center"
                                    Kind="ShieldOff" />
                                <TextBlock
                                    Margin="0,8,0,0"
                                    HorizontalAlignment="Center"
                                    FontSize="14"
                                    FontWeight="Bold"
                                    Text="No Defender" />
                            </StackPanel>
                        </Button>
                        <Button
                            Width="160"
                            Height="120"
                            Margin="0,0,16,16"
                            materialDesign:ButtonAssist.CornerRadius="12"
                            Background="#F5F3FF"
                            Command="{Binding RunDebloatCommand}"
                            Foreground="#5B21B6"
                            Style="{StaticResource MaterialDesignRaisedButton}">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <materialDesign:PackIcon
                                    Width="32"
                                    Height="32"
                                    HorizontalAlignment="Center"
                                    Kind="RocketLaunch" />
                                <TextBlock
                                    Margin="0,8,0,0"
                                    HorizontalAlignment="Center"
                                    FontSize="14"
                                    FontWeight="Bold"
                                    Text="Debloat" />
                            </StackPanel>
                        </Button>
                        <Button
                            Width="160"
                            Height="120"
                            Margin="0,0,16,16"
                            materialDesign:ButtonAssist.CornerRadius="12"
                            Background="#EFF6FF"
                            Command="{Binding RunActivatorCommand}"
                            Foreground="#1E40AF"
                            Style="{StaticResource MaterialDesignRaisedButton}">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <materialDesign:PackIcon
                                    Width="32"
                                    Height="32"
                                    HorizontalAlignment="Center"
                                    Kind="Key" />
                                <TextBlock
                                    Margin="0,8,0,0"
                                    HorizontalAlignment="Center"
                                    FontSize="14"
                                    FontWeight="Bold"
                                    Text="Activate" />
                            </StackPanel>
                        </Button>
                        <Button
                            Width="160"
                            Height="120"
                            Margin="0,0,16,16"
                            materialDesign:ButtonAssist.CornerRadius="12"
                            Background="#F0FDF4"
                            Command="{Binding RunBackupCommand}"
                            Foreground="#166534"
                            Style="{StaticResource MaterialDesignRaisedButton}">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <materialDesign:PackIcon
                                    Width="32"
                                    Height="32"
                                    HorizontalAlignment="Center"
                                    Kind="ContentSaveOutline" />
                                <TextBlock
                                    Margin="0,8,0,0"
                                    HorizontalAlignment="Center"
                                    FontSize="14"
                                    FontWeight="Bold"
                                    Text="Backup" />
                            </StackPanel>
                        </Button>
                    </WrapPanel>
                </materialDesign:Card>
                <TextBlock
                    Margin="0,0,0,12"
                    Foreground="#64748B"
                    Style="{StaticResource MaterialDesignOverlineTextBlock}"
                    Text="RECOVERY CONSOLE" />
                <materialDesign:Card
                    Margin="0,0,0,32"
                    Padding="24"
                    UniformCornerRadius="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Button
                            Grid.Column="0"
                            Height="100"
                            materialDesign:ButtonAssist.CornerRadius="12"
                            Background="#FFEDD5"
                            Command="{Binding RunSystemRestoreCommand}"
                            Foreground="#9A3412"
                            Style="{StaticResource MaterialDesignRaisedButton}">
                            <StackPanel
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Orientation="Horizontal">
                                <materialDesign:PackIcon
                                    Width="32"
                                    Height="32"
                                    VerticalAlignment="Center"
                                    Kind="History" />
                                <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                                    <TextBlock
                                        FontSize="16"
                                        FontWeight="Bold"
                                        Text="System Restore" />
                                    <TextBlock
                                        FontSize="12"
                                        Opacity="0.8"
                                        Text="Revert to an earlier point" />
                                </StackPanel>
                            </StackPanel>
                        </Button>

                        <Button
                            Grid.Column="2"
                            Height="100"
                            materialDesign:ButtonAssist.CornerRadius="12"
                            Background="#FEE2E2"
                            Command="{Binding RunImageRecoveryCommand}"
                            Foreground="#991B1B"
                            Style="{StaticResource MaterialDesignRaisedButton}">
                            <StackPanel
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Orientation="Horizontal">
                                <materialDesign:PackIcon
                                    Width="32"
                                    Height="32"
                                    VerticalAlignment="Center"
                                    Kind="DiscAlert" />
                                <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                                    <TextBlock
                                        FontSize="16"
                                        FontWeight="Bold"
                                        Text="Image Recovery" />
                                    <TextBlock
                                        FontSize="12"
                                        Opacity="0.8"
                                        Text="Reboot to WinRE" />
                                </StackPanel>
                            </StackPanel>
                        </Button>
                    </Grid>
                </materialDesign:Card>
                <TextBlock
                    Margin="0,0,0,12"
                    Foreground="#64748B"
                    Style="{StaticResource MaterialDesignOverlineTextBlock}"
                    Text="SYSTEM TOOLS" />
                <Grid Margin="0,0,0,32">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <materialDesign:Card
                        Grid.Column="0"
                        Padding="24"
                        UniformCornerRadius="16">
                        <StackPanel>
                            <StackPanel Margin="0,0,0,16" Orientation="Horizontal">
                                <materialDesign:PackIcon
                                    Width="24"
                                    Height="24"
                                    VerticalAlignment="Center"
                                    Foreground="#00843D"
                                    Kind="ShieldAccount" />
                                <TextBlock
                                    Margin="8,0,0,0"
                                    VerticalAlignment="Center"
                                    FontWeight="Bold"
                                    Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                                    Text="Antivirus Protection" />
                            </StackPanel>
                            <ComboBox
                                Margin="0,0,0,16"
                                materialDesign:HintAssist.Hint="Select AV Solution"
                                ItemsSource="{Binding AntivirusList}"
                                SelectedItem="{Binding SelectedAntivirus}"
                                Style="{StaticResource MaterialDesignOutlinedComboBox}" />
                            <Button
                                HorizontalAlignment="Stretch"
                                materialDesign:ButtonAssist.CornerRadius="8"
                                Command="{Binding InstallAntivirusCommand}"
                                Content="INSTALL AV"
                                Style="{StaticResource MaterialDesignRaisedButton}" />
                        </StackPanel>
                    </materialDesign:Card>
                    <materialDesign:Card
                        Grid.Column="2"
                        Padding="24"
                        UniformCornerRadius="16">
                        <StackPanel>
                            <StackPanel Margin="0,0,0,16" Orientation="Horizontal">
                                <materialDesign:PackIcon
                                    Width="24"
                                    Height="24"
                                    VerticalAlignment="Center"
                                    Foreground="#2980B9"
                                    Kind="Pill" />
                                <TextBlock
                                    Margin="8,0,0,0"
                                    VerticalAlignment="Center"
                                    FontWeight="Bold"
                                    Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                                    Text="Medicine Cabinet" />
                            </StackPanel>
                            <ComboBox
                                Margin="0,0,0,16"
                                materialDesign:HintAssist.Hint="Select Tool"
                                ItemsSource="{Binding MedicineList}"
                                SelectedItem="{Binding SelectedMedicineName}"
                                Style="{StaticResource MaterialDesignOutlinedComboBox}" />
                            <Button
                                HorizontalAlignment="Stretch"
                                materialDesign:ButtonAssist.CornerRadius="8"
                                Background="#2C3E50"
                                Command="{Binding RunMedicineCommand}"
                                Content="LAUNCH TOOL"
                                Foreground="White"
                                Style="{StaticResource MaterialDesignRaisedButton}" />
                        </StackPanel>
                    </materialDesign:Card>
                </Grid>
                <TextBlock
                    Margin="0,0,0,12"
                    Foreground="#64748B"
                    Style="{StaticResource MaterialDesignOverlineTextBlock}"
                    Text="LIVE TERMINAL" />
                <materialDesign:Card
                    Padding="0"
                    Background="#0F172A"
                    BorderThickness="0"
                    ClipToBounds="True"
                    UniformCornerRadius="16">
                    <Grid Height="350">
                        <TextBox
                            Padding="24"
                            materialDesign:TextFieldAssist.UnderlineBrush="Transparent"
                            Background="Transparent"
                            BorderThickness="0"
                            CaretBrush="#A3E635"
                            FontFamily="Consolas"
                            FontSize="13"
                            Foreground="#A3E635"
                            IsReadOnly="True"
                            Style="{StaticResource MaterialDesignTextBox}"
                            Text="{Binding LogOutput}"
                            TextChanged="Terminal_TextChanged"
                            TextWrapping="Wrap"
                            VerticalScrollBarVisibility="Auto" />
                        <Border
                            Background="#CC00381a"
                            CornerRadius="16"
                            Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <materialDesign:PackIcon
                                    Width="48"
                                    Height="48"
                                    HorizontalAlignment="Center"
                                    Foreground="#A3E635"
                                    Kind="ProgressClock" />
                                <TextBlock
                                    Margin="0,16,0,0"
                                    HorizontalAlignment="Center"
                                    FontSize="16"
                                    FontWeight="Bold"
                                    Foreground="White"
                                    Text="PROCESSING REQUEST..." />
                                <ProgressBar
                                    Width="300"
                                    Height="6"
                                    Margin="0,16,0,0"
                                    Background="#1E293B"
                                    Foreground="#F2C94C"
                                    IsIndeterminate="True" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </materialDesign:Card>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>